<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>Settings</class>
 <widget class="QDialog" name="Settings">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>520</width>
    <height>300</height>
   </rect>
  </property>
  <property name="sizePolicy">
   <sizepolicy hsizetype="Minimum" vsizetype="Minimum">
    <horstretch>0</horstretch>
    <verstretch>0</verstretch>
   </sizepolicy>
  </property>
  <property name="windowTitle">
   <string>Settings</string>
  </property>
  <property name="sizeGripEnabled">
   <bool>true</bool>
  </property>
  <layout class="QVBoxLayout" name="verticalLayout">
   <item>
    <widget class="QFrame" name="frame">
     <property name="frameShape">
      <enum>QFrame::StyledPanel</enum>
     </property>
     <property name="frameShadow">
      <enum>QFrame::Raised</enum>
     </property>
     <layout class="QFormLayout" name="formLayout">
      <item row="0" column="0">
       <widget class="QLabel" name="visibleProfileLabel">
        <property name="text">
         <string>Visible camera profile:</string>
        </property>
       </widget>
      </item>
      <item row="0" column="1">
       <widget class="QComboBox" name="visibleProfileSelect">
        <property name="cursor">
         <cursorShape>PointingHandCursor</cursorShape>
        </property>
       </widget>
      </item>
      <item row="1" column="0">
       <widget class="QLabel" name="irProfileLabel">
        <property name="text">
         <string>IR camera profile:</string>
        </property>
       </widget>
      </item>
      <item row="1" column="1">
       <widget class="QComboBox" name="irProfileSelect">
        <property name="cursor">
         <cursorShape>PointingHandCursor</cursorShape>
        </property>
       </widget>
      </item>
      <item row="2" column="0">
       <widget class="QLabel" name="maxPixmapCacheLabel">
        <property name="text">
         <string>Max. pixmap cache (MB):</string>
        </property>
       </widget>
      </item>
      <item row="2" column="1">
       <widget class="QSpinBox" name="maxPixmapCacheInput">
        <property name="minimum">
         <number>64</number>
        </property>
        <property name="maximum">
         <number>16384</number>
        </property>
        <property name="suffix">
         <string> MB</string>
        </property>
       </widget>
      </item>
      <item row="3" column="1">
       <widget class="QCheckBox" name="enableSecondScreenMirrorCheckbox">
        <property name="text">
         <string>Mirror viewer to a second screen</string>
        </property>
       </widget>
      </item>
      <item row="4" column="1">
       <widget class="QCheckBox" name="enableSharpnessCheckCheckbox">
        <property name="toolTip">
         <string>Compute a Laplace-variance sharpness metric on every loaded capture. Adds ~300 ms to first-time loads of each image; cached afterward.</string>
        </property>
        <property name="text">
         <string>Compute sharpness on each capture (detects defocus + vibration)</string>
        </property>
       </widget>
      </item>
      <item row="5" column="0">
       <widget class="QLabel" name="calibrationReminderLabel">
        <property name="text">
         <string>Calibration reminder:</string>
        </property>
       </widget>
      </item>
      <item row="5" column="1">
       <widget class="QComboBox" name="calibrationTriggerSelect">
        <property name="cursor">
         <cursorShape>PointingHandCursor</cursorShape>
        </property>
        <property name="toolTip">
         <string>When to flag a ColorChecker/Flatfield calibration as due. The shutter buttons stay available regardless of this setting.</string>
        </property>
       </widget>
      </item>
      <item row="6" column="0">
       <widget class="QLabel" name="calibrationIntervalLabel">
        <property name="text">
         <string>Calibration interval:</string>
        </property>
       </widget>
      </item>
      <item row="6" column="1">
       <widget class="QSpinBox" name="calibrationIntervalInput">
        <property name="minimum">
         <number>5</number>
        </property>
        <property name="maximum">
         <number>1440</number>
        </property>
        <property name="suffix">
         <string> min</string>
        </property>
       </widget>
      </item>
      <item row="7" column="0">
       <widget class="QLabel" name="captureHeightsLabel">
        <property name="text">
         <string>Camera heights VIS (cm):</string>
        </property>
       </widget>
      </item>
      <item row="7" column="1">
       <widget class="QLineEdit" name="captureHeightsInput">
        <property name="toolTip">
         <string>Comma-separated VIS camera-height presets, e.g. 30, 45, 60. Used by the capture-row Height control and per-height Flatfield calibration.</string>
        </property>
        <property name="placeholderText">
         <string>30, 45, 60, 75, 90</string>
        </property>
       </widget>
      </item>
      <item row="8" column="0">
       <widget class="QLabel" name="irCaptureHeightLabel">
        <property name="text">
         <string>Camera height IR (cm):</string>
        </property>
       </widget>
      </item>
      <item row="8" column="1">
       <widget class="QLineEdit" name="irCaptureHeightInput">
        <property name="toolTip">
         <string>The single fixed IR camera height (IR uses one height).</string>
        </property>
        <property name="placeholderText">
         <string>45</string>
        </property>
       </widget>
      </item>
      <!-- rotated-sample nudge: remove these two rows to drop the settings UI -->
      <item row="9" column="1">
       <widget class="QCheckBox" name="rotatedSampleNudgeEnabledCheckbox">
        <property name="toolTip">
         <string>Show a reminder to capture a 90°-rotated twin object (same inventory number + _rotiert) of every Nth piece, for the ML light-angle sample.</string>
        </property>
        <property name="text">
         <string>Remind me to capture a rotated twin every Nth piece</string>
        </property>
       </widget>
      </item>
      <item row="10" column="0">
       <widget class="QLabel" name="rotatedSampleNudgeIntervalLabel">
        <property name="text">
         <string>Rotated-sample interval:</string>
        </property>
       </widget>
      </item>
      <item row="10" column="1">
       <widget class="QSpinBox" name="rotatedSampleNudgeIntervalInput">
        <property name="minimum">
         <number>1</number>
        </property>
        <property name="maximum">
         <number>9999</number>
        </property>
        <property name="suffix">
         <string> pieces</string>
        </property>
       </widget>
      </item>
      <!-- end rotated-sample nudge -->
     </layout>
    </widget>
   </item>
   <item>
    <widget class="QDialogButtonBox" name="buttonBox">
     <property name="orientation">
      <enum>Qt::Horizontal</enum>
     </property>
     <property name="standardButtons">
      <set>QDialogButtonBox::Cancel|QDialogButtonBox::Ok</set>
     </property>
    </widget>
   </item>
  </layout>
 </widget>
 <resources/>
 <connections>
  <connection>
   <sender>buttonBox</sender>
   <signal>accepted()</signal>
   <receiver>Settings</receiver>
   <slot>accept()</slot>
  </connection>
  <connection>
   <sender>buttonBox</sender>
   <signal>rejected()</signal>
   <receiver>Settings</receiver>
   <slot>reject()</slot>
  </connection>
 </connections>
</ui>
