+	 * interrupt-event queue, the emulated-filesystem tree and its object-id
+	 * counter as file-scope globals in vcamera.c. A single shared copy
+	 * races and corrupts the heap once two emulated cameras run in one
+	 * process (the papyri VIS+IR dual-vusb setup) — both are linked lists
+	 * mutated with malloc/free from two worker threads. Moving them here
+	 * gives each camera its own independent state (and its own virtual
+	 * filesystem, which is what two real cameras would have anyway).
+	 * `struct ptp_interrupt` / `struct ptp_dirent` are defined in
+	 * vcamera.c; incomplete types are fine for pointers here. */
+	struct ptp_interrupt	*first_interrupt;
+	struct ptp_dirent	*first_dirent;
+	unsigned int		ptp_objectid;
+
